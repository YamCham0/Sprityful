# Add these in your Vercel project or copy to .env.local for local development.
# Keep them server-only. Never expose them with a NEXT_PUBLIC_ prefix.
# Create a Workers AI API token in Cloudflare with Workers AI Read + Edit permissions.
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_workers_ai_api_token

# Supabase browser-safe settings from Project Connect / API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Server-only. Use the modern sb_secret_ key where available, never expose it with NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY is also supported for legacy projects.
SUPABASE_SECRET_KEY=your_supabase_secret_key

# Optional Google AdSense. These values are public identifiers, not secrets.
# Add the client ID to let AdSense verify the site. Set ENABLE_ADS to true only
# after AdSense has approved the site, its consent message is published, and a manual
# responsive display unit has been created for the landing page.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-your_publisher_id
NEXT_PUBLIC_ADSENSE_LANDING_SLOT=your_display_ad_unit_slot
NEXT_PUBLIC_ADSENSE_ENABLE_ADS=false
ADSENSE_PUBLISHER_ID=pub-your_publisher_id
